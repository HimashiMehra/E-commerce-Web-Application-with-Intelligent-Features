# Server
PORT=5000
NODE_ENV=development

# MongoDB — local default (change to Atlas URI for production)
MONGO_URI=mongodb://localhost:27017/amazon-clone

# JWT
JWT_SECRET=amazon_clone_super_secret_jwt_key_2024_change_in_production
JWT_EXPIRE=7d

# Stripe — replace with your Stripe test keys from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Frontend URL (for CORS + Stripe redirect)
CLIENT_URL=http://localhost:5500

# Admin seed account
ADMIN_EMAIL=admin@amazon-clone.com
ADMIN_PASSWORD=Admin@123456
